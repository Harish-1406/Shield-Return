{
  "functions": {
    "source": "functions",
    "ignore": [
      "node_modules/**",
      ".git/**",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "*.local"
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "emulators": {
    "ui": {
      "enabled": true,
      "port": 4100
    },
    "functions": {
      "port": 5100
    },
    "firestore": {
      "port": 8200
    },
    "auth": {
      "port": 9200
    },
    "eventarc": {
      "port": 9300
    },
    "tasks": {
      "port": 9500
    },
    "singleProjectMode": true
  }
}